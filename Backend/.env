# RapidCare Backend — Environment Variables
# Copy this file to .env and fill in real values before deploying.

# ── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────
# Path is relative to Backend/server.js
DB_PATH=./user_Database/rapidcare.db

# ── Authentication ───────────────────────────────────
# IMPORTANT: Change this to a strong random secret before deploying!
JWT_SECRET=super_secret_rapidcare_key_2026
JWT_EXPIRY=24h
