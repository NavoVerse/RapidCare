# ═══════════════════════════════════════════════════════════════════════════════
# RapidCare Backend — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════════════
# 
# SETUP INSTRUCTIONS:
#   1. Copy this file to .env          →  cp .env.example .env
#   2. Fill in the values below        →  especially JWT_SECRET and SMTP
#   3. Run the app                     →  npm start
#
# Or just run:  npm run setup   (creates .env automatically)
# ═══════════════════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────
# DB_TYPE can be 'sqlite' (default for dev) or 'postgresql' (for production)
DB_TYPE=sqlite

# Path for SQLite (relative to Backend/)
DB_PATH=./user_Database/rapidcare.db

# For PostgreSQL (set DB_TYPE=postgresql above):
# DATABASE_URL=postgres://user:password@localhost:5432/rapidcare

# ── Authentication ───────────────────────────────────
# IMPORTANT: Change this to a strong random secret before deploying!
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=24h

# ── Encryption ──────────────────────────────────────
# AES-256 key for encrypting sensitive medical data (exactly 32 characters)
ENCRYPTION_KEY=rapidcare_default_secret_key_32_c

# ── Email / SMTP ────────────────────────────────────
# Required for sending OTP emails. If left blank, OTPs are logged to console.
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="RapidCare Support <no-reply@rapidcare.com>"

# ── Razorpay (Payments) ─────────────────────────────
# Optional: only needed if you're using Razorpay payment integration
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Logging ─────────────────────────────────────────
# LOG_LEVEL: error, warn, info, debug
LOG_LEVEL=info
# Set to 'true' to see raw SQL queries in development
KNEX_DEBUG=false
