# RapidCare Backend — Environment Variables Template
# Copy this file to .env and fill in real values.

# ── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────
# For Development (SQLite):
DB_PATH=./user_Database/rapidcare.db

# For Production (PostgreSQL):
# Set DB_TYPE to 'postgresql' to use PG instead of SQLite
DB_TYPE=sqlite
DATABASE_URL=postgres://user:password@localhost:5432/rapidcare

# ── Authentication ───────────────────────────────────
# Change this to a strong random secret!
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=24h

# ── Security ────────────────────────────────────────
# AES keys for medical data encryption (32 chars / 16 chars)
AES_KEY=rapidcare_secure_encryption_key_32
AES_IV=rapidcare_sec_iv_16

# ── Email Settings (SMTP) ───────────────────────────
# Host for your SMTP provider (e.g., smtp.gmail.com)
SMTP_HOST=
# Port (587 for TLS, 465 for SSL)
SMTP_PORT=587
# Your email address
SMTP_USER=
# Your email password or App Password
SMTP_PASS=
# The display name/email the user will see
EMAIL_FROM="RapidCare Support <no-reply@rapidcare.com>"
